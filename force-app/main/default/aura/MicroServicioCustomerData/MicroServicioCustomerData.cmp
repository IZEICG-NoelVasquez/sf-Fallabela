<aura:component controller="MicroServicioCustomerData">
    <aura:registerEvent name="CustomerDataPhoneE" type="c:CustomerDataPhoneE" />
    <aura:attribute name="selectedAccount" type="Object" />
    <aura:attribute name="esUsuarioAppWeb" type="Boolean" />
    <aura:attribute name="Response" type="String" />
    <aura:handler name="init" value="{! this }" action="{! c.doInit }" />      
</aura:component>