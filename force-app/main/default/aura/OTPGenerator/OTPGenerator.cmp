<aura:component controller="SendOTPController">
    
    <aura:registerEvent name="stepChange" type="c:stepChange" />
    <aura:registerEvent name="OTPValidated" type="c:OTPValidated" />
    <aura:handler name="CustomerDataPhoneE" event="c:CustomerDataPhoneE" action="{! c.handleCustomerDataPhoneE }" />  
    <aura:attribute name="phoneCustomerData" type="String" />
    <aura:method name="setState" action="{! c.doSetState }" >
        <aura:attribute name="state" type="String" default="closed"/>
    </aura:method>
    
    <aura:method name="setMode" action="{! c.doSetMode }" >
        <aura:attribute name="mode" type="String" default="contact"/>
    </aura:method>
    
    <aura:method name="setPhone" action="{! c.doSetPhone }" >
        <aura:attribute name="phone" type="String" />
    </aura:method>
    
    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="customer" type="Object" />
    <aura:attribute name="step" type="Integer" default="1"/>
    <aura:attribute name="mode" type="String" default="contact"/>
    <aura:attribute name="phone" type="String" />
    <aura:attribute name="tipificacion" type="String" />
    <aura:attribute name="rqstFailures" type="Integer" default="0"/>

    <aura:attribute name="configServicio" type="String" />
    <aura:attribute name="numeroDocumento" type="String" />
    <aura:attribute name="configServicioLoaded" type="Boolean" default="false" />
    
    <aura:handler name="init" value="{! this }" action="{! c.doInit }" />
    
    <aura:attribute name="blnUpdateMobile" type="Boolean" default="false" />
    <aura:attribute name="mobilePhoneUpdate" type="String" />
    <aura:attribute name="mobilePhoneUpdate4Dig" type="String" />
    <aura:registerEvent name="OTPClose" type="c:OTPClose" />

    <aura:attribute name="otpEnviadoValidado" type="Boolean" default="true" />
    
    <div aura:id="modal-section" class="demo-only slds-hide" style="height: 640px;">
        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
            <div class="slds-modal__container">
                <header class="slds-modal__header">
                    <lightning:buttonIcon class="slds-modal__close" onclick="{! c.closeModal }" iconName="utility:close" variant="bare" alternativeText="Close" iconClass="dark"/>
                    <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">
                        <aura:text value="VALIDACI&Oacute;N OTP" />
                    </h2>
                </header>
                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">

                     <aura:if isTrue="{!v.customer!=null}">
                        <c:Send_OTP customer="{! v.customer }" mode="{! v.mode }" phone="{! v.phone }" blnUpdateMobile="{! v.blnUpdateMobile }" mobilePhoneUpdate="{! v.mobilePhoneUpdate4Dig }" />
                        <lightning:input aura:id="codigo_verificacion" type="text" name="number" label="Codigo de Verificacion" pattern="[0-9]*" />
                    </aura:if>

                </div>
                <footer class="slds-modal__footer slds-is-relative">
                    <aura:if isTrue="{! and( v.otpEnviadoValidado, v.configServicioLoaded) }" >
                        <lightning:button label="Validar Codigo" onclick="{! c.doValidate }"/>
                        <lightning:button label="Enviar Codigo" variant="brand" onclick="{! c.doSend }"/>

                        <aura:set attribute="else">
                            <div class="slds-m-vertical_small slds-p-around_medium">
                                <lightning:spinner variant="brand" alternativeText="Loading" />
                            </div>                                            
                        </aura:set>
                    </aura:if>
                    
                </footer>
            </div>
        </section>
        <div class="slds-backdrop slds-backdrop_open"></div>
    </div>
    
</aura:component>