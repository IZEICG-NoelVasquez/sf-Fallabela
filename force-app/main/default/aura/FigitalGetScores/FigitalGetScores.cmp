<aura:component controller="FigitalGetScores" implements="force:lightningQuickActionWithoutHeader,lightning:isUrlAddressable,flexipage:availableForAllPageTypes" access="global" >

    <aura:attribute name="callingMSIncode" type="Boolean" />

    <aura:attribute name="scoreAlreadyCreated" type="Boolean" default="false" />

    <aura:attribute name="msgScoreCreatedSuccessfully" type="String" default="Se crearon los Scores con éxito." />
    <aura:attribute name="msgScoresAlreadyCreated" type="String" default="El Score ya fue consultado anteriormente." />
    <aura:attribute name="msgScoresError" type="String" default="Ocurrió un error al consultar el Score. Por favor inténtelo nuevamente." />

    <aura:attribute name="msgMSIncode" type="String" default="" />

    <aura:handler name="init" value="{! this }" action="{! c.doInit }" />

    <lightning:workspaceAPI aura:id="workspace" />

    <!--###### MODAL BOX Start######--> 
    <div class="slds-m-around_xx-large">
        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open slds-modal_x-small">
                            
            <div class="slds-modal__container">
                <!-- ###### MODAL BOX HEADER Start ######-->
                <header class="slds-modal__header slds-modal__header_empty">
                    <lightning:buttonIcon iconName="utility:close"
                                            onclick="{! c.closeModalFigital }"
                                            disabled="{! v.callingMSIncode }"
                                            alternativeText="close"
                                            variant="bare-inverse"
                                            class="slds-modal__close"/>                       
                </header>
                <lightning:card class="slds-text-heading_medium slds-text-title_bold" title="Obtener scores" iconName="standard:case" />
                <!--###### MODAL BOX BODY Part1 Start######-->
                <div class="slds-modal__content slds-p-around_x-large slds-is-relative" id="modal-content-id-1">
                    <aura:if isTrue="{! (!v.callingMSIncode) }" >

                        <div class="slds-p-around_x-large">
                            {!v.msgMSIncode}            
                        </div>

                        <div class="slds-text-align_right slds-p-top_medium" >
                            <lightning:button variant="neutral" 
                                                        label="Regresar"
                                                        title="Regresar"
                                                        onclick="{! c.closeModalFigital }"
                                                        disabled="{! v.callingMSIncode }" />
                        </div>  

                        <aura:set attribute="else">
                            <div class="slds-p-around_xx-large">
                                <lightning:spinner variant="brand" alternativeText="Loading" />
                            </div>  
                        </aura:set>
                    </aura:if>
                </div>
            </div>
        </section>
        <div class="slds-backdrop slds-backdrop_open"></div>
    </div>

</aura:component>