                    <p class="slds-text-heading--small">
                        <lightning:formattedNumber  title="Diferencia" value="{!v.simpleRecord.Error_MC_CONTACLESS_Diferencia__c}" /></p>
                </div>
                <div class="slds-col slds-size_1-of-2">     
                    Comentarios<br/>
                    <p class="slds-text-heading--small">
                        <lightning:formattedText title="Comentarios" value="{!v.simpleRecord.Error_MC_CONTACLESS_Comentarios__c}" /></p>
                </div>
            </div>
            <h3 class="slds-section__title slds-theme_shade">
                <div class="slds-section__title-action">
                    Información General
                </div>
            </h3>
            <div class="slds-grid">
                <div class="slds-col slds-size_1-of-2">
                    Status<br/>
                    <p class="slds-text-heading--small">
                        <lightning:formattedText title="Status" value="{!v.simpleRecord.Status__c}" /></p>
                </div>
                <div class="slds-col slds-size_1-of-2">
                    Sucursal<br/>
                    <p class="slds-text-heading--small">
                        <lightning:formattedText title="Sucursal" value="{!v.simpleRecord.Sucursal__c}" /></p>
                </div>
            </div>
        </aura:if>
    </lightning:card>
    <!-- Display Lightning Data Service errors, if any -->
    <aura:if isTrue="{!not(empty(v.recordError))}">
        <div class="recordError">
            {!v.recordError}
        </div>
    </aura:if>
</aura:component>