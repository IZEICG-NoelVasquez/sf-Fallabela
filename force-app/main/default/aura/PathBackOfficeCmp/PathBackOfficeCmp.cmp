<aura:component implements="flexipage:availableForAllPageTypes,force:hasRecordId" >
    <aura:attribute name="fields" type="String[]" default="['Fecha_y_hora_en_autorizacin__c','Coordinadores_y_Gerentes_Ausentes__c','Evaluar__c','Clasificaci_n_Back_Office__c','Motivo_de_Pendiente__c','Motivo_de_Rechazo_Riesgos__c','Submotivo_de_Rechazo__c']" />
    <aura:attribute name="caseStatus" type="String" default="" />

    
    <aura:attribute name="caseRecord" type="Object"/>
    <aura:attribute name="recordLoadError" type="String"/>
    
    <aura:handler name="init" value="{! this }" action="{! c.doInit }" />

    <force:recordData aura:id="recordLoader"
                    recordId="{!v.recordId}"
                    fields="Status"
                    targetFields="{!v.caseRecord}"
                    targetError="{!v.recordLoadError}"
                    />
   <aura:handler name="change" value="{!v.caseRecord.Status}" action="{!c.changeStatus}"/>

<div>
    <div class="slds-p_medium" >
        <lightning:path aura:id="path" recordId="{!v.recordId}"
            variant="linear"
            hideUpdateButton="false"
            onselect="{!c.handleSelect}"
        />
    </div>
  <aura:if isTrue="{! v.caseStatus == 'Autorización' }">
  
    <lightning:recordForm
    aura:id="myRecordForm"
    recordId="{!v.recordId}"
    objectApiName="Case"
    fields="{!v.fields}"
    columns="1"
    mode="edit"
  
     />

  
  </aura:if>
</div>
</aura:component>