<aura:component implements="force:appHostable" controller="MicroServicioBuroCreditoBO">

    <aura:handler name="init" value="{!this}" action="{!c.getData}" />
    <aura:attribute name="Persona" type="Object" />
    <aura:attribute name="PersonaJson" type="String" />
    <aura:attribute name="currentYear" type="integer" />

    <div class='main'>

        <div class="slds-grid slds-gutters footer logos">

            <div class="slds-col slds-size_10-of-12">

                <div class="content-img">
                    <img alt="falabella" src="https://www.falabella.com.mx/assets/logo-falabella-soriana.svg" />
                </div>

            </div>

            <div class="slds-col slds-size_2-of-12">

                <dl class="slds-dl_inline txt-logos">

                    <dt class="slds-dl_inline__label">
                        NUMERO DE CONTROL:
                    </dt>
                    <dd class="slds-dl_inline__detail">{!v.Persona.encabezado.NumeroControlConsulta}</dd>

                    <dt class="slds-dl_inline__label">
                        FECHA DE CONSULTA:
                    </dt>
                    <dd class="slds-dl_inline__detail">{!v.Persona.consultasEfectuadas[0].FechaConsulta}</dd>

                </dl>

            </div>


        </div>
        <div class="slds-text-heading_large logos">REPORTE DE CREDITO</div>

        <!--Datos generales-->
        <div class="slds-grid slds-gutters title">
            <div class="slds-col slds-size_7-of-7">
                <span><B>DATOS GENERALES</B></span>
            </div>
        </div>

        <table class="slds-table slds-table_cell-buffer slds-table_bordered tabJM">
            <thead>
                <tr class="slds-line-height_reset">
                    <th class="" scope="col">
                        <div class="slds-truncate " title="Nombre">NOMBRE(S)</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate" title="Apellidos">APELLIDOS</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate" title="RFC">RFC</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate" title="fechNacimiento">FECHA DE NACIMIENTO</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate" title="IFE">IFE</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate" title="CURP">CURP</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate" title="regBC">REGISTRO EN BC</div>
                    </th>
                </tr>
            </thead>
            <tbody>
                <tr class="slds-hint-parent">
                    <th data-label="Nombre" scope="row">
                        <div class="slds-truncate">
                            {!v.Persona.nombre.PrimerNombre}&nbsp;&nbsp;{!v.Persona.nombre.SegundoNombre}
                        </div>
                    </th>
                    <th data-label="Apellidos" scope="row">
                        <div class="slds-truncate">
                            {!v.Persona.nombre.ApellidoPaterno}&nbsp;&nbsp;{!v.Persona.nombre.ApellidoMaterno}
                        </div>
                    </th>
                    <th data-label="RFC" scope="row">
                        <div class="slds-truncate">
                            {!v.Persona.nombre.RFC}
                        </div>
                    </th>
                    <th data-label="fechNacimiento" scope="row">
                        <div class="slds-truncate">
                            {!v.Persona.nombre.FechaNacimiento}
                        </div>
                    </th>
                    <th data-label="IFE" scope="row">
                        <div class="slds-truncate">
                            {!v.Persona.nombre.NumeroRegistroElectoral}
                        </div>
                    </th>
                    <th data-label="CURP" scope="row">
                        <div class="slds-truncate">
                            {!v.Persona.nombre.ClaveImpuestosOtroPais}
                        </div>
                    </th>
                    <th data-label="regBC" scope="row">
                        <div class="slds-truncate">
                            {!v.Persona.ResumenReportes[0].FechaIngresoBD}
                        </div>
                    </th>

                </tr>
            </tbody>
        </table>

        <!--Domicilios reportados-->
        <div class="slds-grid slds-gutters title">
            <div class="slds-col slds-size_7-of-7">
                <span><B>DOMICILIO(S) REPORTADOS(S)</B></span>
            </div>
        </div>

        <table class="slds-table slds-table_cell-buffer slds-table_bordered tabJM">
            <thead>
                <tr class="slds-line-height_reset">
                    <th class="" scope="col">
                        <div class="slds-truncate " title="Num">
                            <lightning:icon iconName="standard:topic2" size="X-Small" alternativeText="Fecha" />
                        </div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate" title="CALLEYNUMERO ">CALLE Y NUMERO </div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate" title="COLONIA">COLONIA</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate" title="DELMPIO">DEL / MPIO</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate" title="CIUDAD">CIUDAD</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate" title="EDO">EDO</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate" title="CP">CP</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate" title="TEL">TEL</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate" title="PAIS">PAIS</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate" title="REGISTROENBC">REGISTRO EN BC</div>
                    </th>
                </tr>
            </thead>
            <aura:iteration items="{!v.Persona.domicilios}" var="item">
                <tbody>
                    <tr class="slds-hint-parent">
                        <th data-label="NUM" scope="row">
                            <div class="slds-truncate">
                                {!_index + 1}
                            </div>
                        </th>
                        <th data-label="CALLEYNUMERO" scope="row">
                            <div class="slds-truncate">
                                {!item.Direccion1}
                            </div>
                        </th>
                        <th data-label="COLONIA" scope="row">
                            <div class="slds-truncate">
                                {!item.ColoniaPoblacion}
                            </div>
                        </th>
                        <th data-label="DELMPIO" scope="row">
                            <div class="slds-truncate">
                                {!item.DelegacionMunicipio}
                            </div>
                        </th>
                        <th data-label="CIUDAD" scope="row">
                            <div class="slds-truncate">
                                {!item.Ciudad}
                            </div>
                        </th>
                        <th data-label="EDO" scope="row">
                            <div class="slds-truncate">
                                {!item.Estado}
                            </div>
                        </th>
                        <th data-label="CP" scope="row">
                            <div class="slds-truncate">
                                {!item.CP}
                            </div>
                        </th>
                        <th data-label="TEL" scope="row">
                            <div class="slds-truncate">
                                {!item.NumeroTelefono}
                            </div>
                        </th>
                        <th data-label="PAIS" scope="row">
                            <div class="slds-truncate">
                                {!item.CodPais}
                            </div>
                        </th>
                        <th data-label="REGISTROENBC" scope="row">
                            <div class="slds-truncate">
                                {!item.FechaReporteDireccion}
                            </div>
                        </th>
                    </tr>
                </tbody>
            </aura:iteration>
        </table>

        <!--DOMICILIO(S) DE EMPLEO(S) REPORTADO(S)-->
        <div class="slds-grid slds-gutters title">
            <div class="slds-col slds-size_7-of-7">
                <span><B>DOMICILIO(S) DE EMPLEO(S) REPORTADO(S)</B></span>
            </div>
        </div>

        <table class="slds-table slds-table_cell-buffer slds-table_bordered tabJM">
            <thead>
                <tr class="slds-line-height_reset">

                    <th class="" scope="col">
                        <div class="slds-truncate " title="Num">
                            <lightning:icon iconName="standard:topic2" size="X-Small" alternativeText="Fecha" />
                        </div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="COMPAIA">COMPAIA</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="PUESTO">PUESTO</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="SALARIO">SALARIO</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="BASE">BASE</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="CALLEYNUMERO">CALLE Y NUMERO </div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="COLONIA">COLONIA</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title=" DELMPIO"> DEL / MPIO </div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="CIUDAD">CIUDAD</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="EDO ">EDO</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="CP ">CP</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="TEL ">TEL</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="PAIS ">PAIS</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="REGISTROENBC ">REGISTRO <br></br>EN BC </div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="FECHACONTRATACION ">FECHA <br></br>CONTRATACION </div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="ULTIMODIAEMPLEO">ULTIMO DIA <br></br>EMPLEO </div>
                    </th>

                </tr>
            </thead>
            <aura:iteration items="{!v.Persona.empleos}" var="item">
                <tbody>
                    <tr class="slds-hint-parent">

                        <th data-label="NUM" scope="row">
                            <div class="slds-truncate">
                                {!_index + 1}
                            </div>
                        </th>
                        <th data-label="COMPAIA" scope="row">
                            <div class="slds-truncate">
                                {!item.NombreEmpresa}
                            </div>
                        </th>
                        <th data-label="PUESTO" scope="row">
                            <div class="slds-truncate">
                                {!item.Cargo}
                            </div>
                        </th>
                        <th data-label="SALARIO" scope="row">
                            <div class="slds-truncate">
                                {!item.Salario}
                            </div>
                        </th>
                        <th data-label="BASE" scope="row">
                            <div class="slds-truncate">
                                {!item.BaseSalarial}
                            </div>
                        </th>
                        <th data-label="CALLEYNUMERO" scope="row">
                            <div class="slds-truncate">
                                {!item.Direccion1}, {!item.Direccion2}
                            </div>
                        </th>
                        <th data-label="COLONIA" scope="row">
                            <div class="slds-truncate">
                                {!item.ColoniaPoblacion}
                            </div>
                        </th>
                        <th data-label="DELMPIO" scope="row">
                            <div class="slds-truncate">
                                {!item.DelegacionMunicipio}
                            </div>
                        </th>
                        <th data-label="CIUDAD" scope="row">
                            <div class="slds-truncate">
                                {!item.Ciudad}
                            </div>
                        </th>
                        <th data-label="EDO" scope="row">
                            <div class="slds-truncate">
                                {!item.Estado}
                            </div>
                        </th>
                        <th data-label="CP" scope="row">
                            <div class="slds-truncate">
                                {!item.CP}
                            </div>
                        </th>
                        <th data-label="TEL" scope="row">
                            <div class="slds-truncate">
                                {!item.NumeroTelefono}
                            </div>
                        </th>
                        <th data-label="PAIS" scope="row">
                            <div class="slds-truncate">
                                {!item.CodPais}
                            </div>
                        </th>
                        <th data-label="REGISTROENBC" scope="row">
                            <div class="slds-truncate">
                                {!item.FechaReportoEmpleo}
                            </div>
                        </th>
                        <th data-label="FECHACONTRATACION" scope="row">
                            <div class="slds-truncate">
                                {!item.FechaContratacion}
                            </div>
                        </th>
                        <th data-label="ULTIMODIAEMPLEO" scope="row">
                            <div class="slds-truncate">
                                {!item.FechaUltimoDiaEmpleo}
                            </div>
                        </th>

                    </tr>
                </tbody>
            </aura:iteration>
        </table>

        <!--MENSAJES-->
        <div class="slds-grid slds-gutters title">
            <div class="slds-col slds-size_7-of-7">
                <span><B>MENSAJES</B></span>
            </div>
        </div>

        <table class="slds-table slds-table_cell-buffer slds-table_bordered tabJM">
            <thead>
                <tr class="slds-line-height_reset">
                    <th class="" scope="col">
                        <div class="slds-truncate " title="Num">
                            <lightning:icon iconName="standard:topic2" size="X-Small" alternativeText="Fecha" />
                        </div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="MSJ">Mensaje</div>
                    </th>
                </tr>
            </thead>
            <aura:iteration items="no hay mensajes" var="item">
                <tbody>
                    <tr class="slds-hint-parent">
                        <th data-label="NUM" scope="row">
                            <div class="slds-truncate">
                                {!_index + 1}
                            </div>
                        </th>
                        <th data-label="MSJ" scope="row">
                            <div class="slds-truncate">
                                {!item}
                            </div>
                        </th>
                    </tr>
                </tbody>
            </aura:iteration>
        </table>

