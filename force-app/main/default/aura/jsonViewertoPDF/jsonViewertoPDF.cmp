        <table class="slds-table slds-table_cell-buffer slds-table_bordered tabJM">
            <thead>
                <tr class="slds-line-height_reset">
                    <th class="" scope="col">
                        <div class="slds-truncate " title="OTORGANTE">OTORGANTE</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="FECHADELACONSULTA">FECHA DE LA CONSULTA</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="RESPONSABILIDAD">RESPONSABILIDAD</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="TIPODECONTRATO">TIPO DE CONTRATO</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="IMPORTE">IMPORTE</div>
                    </th>
                    <th class="" scope="col">
                        <div class="slds-truncate " title="TIPODEMONEDA">TIPO DE MONEDA</div>
                    </th>
                </tr>
            </thead>
            <aura:iteration items="{!v.Persona.consultasEfectuadas}" var="item">
                <tbody>
                    <tr class="slds-hint-parent">
                        
                        <th data-label="OTORGANTE" scope="row">
                            <div class="slds-truncate">
                                {!item.NombreOtorgante}
                            </div>
                        </th>
                        <th data-label="FECHADELACONSULTA" scope="row">
                            <div class="slds-truncate">
                                {!item.FechaConsulta}
                            </div>
                        </th>
                        <th data-label="RESPONSABILIDAD" scope="row">
                            <div class="slds-truncate" style="text-transform: uppercase;">
                                {!item.IndicadorTipoResponsabilidad}
                            </div>
                        </th>
                        <th data-label="TIPODECONTRATO" scope="row">
                            <div class="slds-truncate" style="text-transform: uppercase;">
                                {!item.TipoContrato}
                            </div>
                        </th>
                        <th data-label="IMPORTE" scope="row">
                            <div class="slds-truncate">
                                {!item.ImporteContrato}
                            </div>
                        </th>
                        <th data-label="TIPODEMONEDA" scope="row">
                            <div class="slds-truncate">
                                {!item.ClaveUnidadMonetaria}
                            </div>
                        </th>
                    </tr>
                </tbody>
            </aura:iteration>
        </table>

        <div class="slds-text-heading_small titlefooter">* MONTO: puede tener las siguientes interpretaciones:</div>

        <!--footer-->
        <div class="slds-grid slds-gutters footer">

            <div class="slds-col">

                <dl class="slds-dl_inline">
                    <dt class="slds-dl_inline__label">1)</dt>
                    <dd class="slds-dl_inline__detail">
                        Saldo Vencido (monto no pagado a la fecha límite de pago)
                    </dd>
                    <dt class="slds-dl_inline__label">2)</dt>
                    <dd class="slds-dl_inline__detail">
                        Monto de la Quita otorgada (con clave de observación LC - esinformativo)
                    </dd>
                    <dt class="slds-dl_inline__label">3)</dt>
                    <dd class="slds-dl_inline__detail">
                        Saldo Vencido al momento de la venta de la cartera (con clave de observación CV - es
                        informativo)
                    </dd>
                </dl>

            </div>


            <div class="slds-col">

                <dl class="slds-dl_inline">

                    <dt class="slds-dl_inline__label">
                        <lightning:icon iconName="standard:topic2" size="XX-Small" alternativeText="Fecha" />
                    </dt>
                    <dd class="slds-dl_inline__detail">INDICA NUMERACIÓN DE REGISTROS</dd>

                    <dt class="slds-dl_inline__label">
                        <lightning:icon iconName="standard:dashboard" size="XX-Small" alternativeText="Fecha" />
                    </dt>
                    <dd class="slds-dl_inline__detail">MAX MOROS.</dd>

                    <dt class="slds-dl_inline__label">
                        <lightning:icon iconName="standard:currency" size="XX-Small" alternativeText="Fecha" />
                    </dt>
                    <dd class="slds-dl_inline__detail">INDICA CANTIDADES</dd>

                    <dt class="slds-dl_inline__label">
                        <lightning:icon iconName="standard:event" size="XX-Small" alternativeText="Fecha" />
                    </dt>
                    <dd class="slds-dl_inline__detail">INDICA FECHAS</dd>
                    <dt class="slds-dl_inline__label">
                        <lightning:icon iconName="standard:user" size="XX-Small" alternativeText="Fecha" />
                    </dt>
                    <dd class="slds-dl_inline__detail">INDICA CUENTAS ABIERTAS</dd>
                    <dt class="slds-dl_inline__label">
                        <lightning:icon iconName="standard:user" size="XX-Small" alternativeText="Fecha"
                            class="blackOnRed" />
                    </dt>
                    <dd class="slds-dl_inline__detail">INDICA CUENTAS CERRADAS</dd>

                </dl>

            </div>

        </div>

        <div class="slds-grid slds-gutters titleDown">
            <div class="slds-col slds-size_12-of-12">
                <span><B>DOCUMENTO SIN VALOR PROBATORIO EN JUICIOS</B></span>
            </div>
        </div>

    </div>


</aura:component>